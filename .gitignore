############################################################
# R files
############################################################

.Rhistory
.RData
.Ruserdata

# RStudio project files
.Rproj.user/

############################################################
# Data (patient-level data should never be uploaded)
############################################################

data/raw/*
data/processed/*

# Allow folder structure to remain
!data/raw/.gitkeep
!data/processed/.gitkeep

############################################################
# Large analysis objects
############################################################

*.rds
*.rda
*.RData
*.csv
*.xlsx

# Exception: allow selected result tables if desired
!results/*.csv

############################################################
# Output files
############################################################

results/*.html
results/*.pdf
results/*.png
results/*.jpeg

############################################################
# Temporary files
############################################################

*.tmp
*.log
*.bak
*.swp
*~

############################################################
# Operating system files
############################################################

.DS_Store
Thumbs.db

############################################################
# IDE / editor files
############################################################

.vscode/
.idea/

############################################################
# Sensitive local files
############################################################

*.key
*.pem
.env
